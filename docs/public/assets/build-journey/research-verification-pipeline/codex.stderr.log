    layer = layer.filter(ImageFilter.GaussianBlur(12))
    return Image.alpha_composite(base, layer)

def draw_centered_text(draw, center, text, font, fill, shadow=None):
    bbox = draw.textbbox((0, 0), text, font=font)
    x = center[0] - (bbox[2] - bbox[0]) / 2
    y = center[1] - (bbox[3] - bbox[1]) / 2 - 4
    if shadow:
        draw.text((x+shadow[0], y+shadow[1]), text, font=font, fill=shadow[2])
    draw.text((x, y), text, font=font, fill=fill)

